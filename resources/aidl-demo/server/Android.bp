// server/Android.bp — 人类写

cc_binary {
    name: "myserver",
    srcs: [
        "main.cpp",
        "StringService.cpp",
    ],
    shared_libs: [
        "com.example.binder-cpp",   // ← aidl_interface 自动产生的库
        "libbinder",                //    AOSP 系统库: BBinder/BpBinder/IPCThreadState
        "libutils",                 //    AOSP 系统库: String16/sp<>
    ],
}
